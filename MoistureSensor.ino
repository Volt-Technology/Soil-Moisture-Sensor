float konversi(int adc){
  float persen = (kering - adc) * 100.0 / (kering - basah);
  return constrain(persen, 0.0, 100.0);
}

kondisi air(float persen){
  if(persen < batasKering) return KERING;
  if(persen < batasLembab) return LEMBAB;
  return BASAH;
}

const char* tampilKondisi(kondisi hitung){
  switch(hitung){
    case KERING:
    return "STATUS -> KERING";

    case LEMBAB:
    return "STATUS -> LEMBAB";

    case BASAH:
    return "STATUS -> BASAH";

    default:
    return "TIDAK DIKETAHUI";
  }
}

void gambar(kondisi hitung){
  switch(hitung){
    case KERING:
    display.drawBitmap(90, 6, gelasKering, 34, 44, SSD1306_WHITE);
    break;

    case LEMBAB:
    display.drawBitmap(90, 6, gelasLembab, 34, 44, SSD1306_WHITE);
    break;

    case BASAH:
    display.drawBitmap(90, 6, gelasBasah, 34, 44, SSD1306_WHITE);
    break; 
  }
}

void setup() {
  Serial.begin(9600);
  pinMode(sensor, INPUT);
  pinMode(merah, OUTPUT);
  pinMode(kuning, OUTPUT);
  pinMode(hijau, OUTPUT);

  if(!display.begin(SSD1306_SWITCHCAPVCC, 0x3C)){
    Serial.println("OLED gagal di-inisialisasi!");
    for(;;);
  }

  display.clearDisplay();
  display.setTextSize(1);
  display.setTextColor(SSD1306_WHITE);
}

void loop() {
  if(millis() - akhir >= 500){
    akhir = millis();

    int adc = analogRead(sensor);
    float persen = konversi(adc);

    kondisi hitung = air(persen);

    Serial.print("ADC -> ");
    Serial.print(adc);
    Serial.print(" | ");
    Serial.print("Persen -> ");
    Serial.print(persen, 1);
    Serial.print("% | ");
    Serial.println(tampilKondisi(hitung));

    gantiLampu(hitung);
    oled(persen, hitung);

  }
}

void oled(float persen, kondisi oledd){
  display.clearDisplay();
  gambar(oledd);
  
  display.setTextSize(2);
  display.setCursor(0, 5);
  display.print("KONDISI");

  display.setTextSize(2);
  display.setCursor(5, 27);
  display.print(persen,1);
  display.print("%");

  display.setTextSize(1);
  display.setCursor(0, 53);
  display.print(tampilKondisi(oledd));
  display.display();
}

void gantiLampu(kondisi status){
  digitalWrite(merah, status == KERING);
  digitalWrite(kuning, status == LEMBAB);
  digitalWrite(hijau, status == BASAH);
}
